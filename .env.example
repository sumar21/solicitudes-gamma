# Grupo Gamma API credentials — set these in Vercel environment variables.
# Never commit real values here.

# VM proxy URL (defaults to http://35.224.5.114/proxy/index.php if not set)
# GAMMA_VM_URL=http://35.224.5.114/proxy/index.php

# Microsoft Graph / SharePoint (Azure AD App Registration)
AZURE_TENANT_ID=your_tenant_id_here
AZURE_CLIENTE_ID=your_client_id_here
AZURE_CLIENT_SECRET=your_client_secret_here
SHAREPOINT_SITE_ID=your_site_id_here

# JWT — usá un string aleatorio largo (ej: openssl rand -base64 32)
JWT_SECRET=your_long_random_secret_here
# List IDs are hardcoded in each api/*.ts file (structural constants, not secrets)

# Upstash Redis — rate limiting del login (anti brute-force).
# Si están seteadas, el rate limit se persiste en Redis (compartido entre instancias Vercel
# y sobrevive cold-starts). Si no están, fallback a contador in-memory por instancia.
# Setup:
#   1. Crear cuenta gratis en https://upstash.com → Create Database (Global, plan Free).
#   2. En el dashboard de la DB, copiar "REST URL" y "REST Token" (sección "REST API").
#   3. Pegar los valores acá y replicarlos en Vercel: Settings → Environment Variables.
# UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AYxxxxx...
